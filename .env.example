# Verifiable Agents — client config.
# All vars are public (NEXT_PUBLIC_*), baked at build time. No secrets here.
# Copy to .env.local and adjust. Secrets (API keys, signer keys) live in the GATEWAY, never here.

# Backend gateway base URL — the client needs a running gateway.
# Until the sanitized gateway repo ships, you can point at the hosted one.
NEXT_PUBLIC_GATEWAY_URL=https://gateway.ensub.org

# Reference ENS identity for this deployment (drives page records + branding).
NEXT_PUBLIC_ENS_NAME=vertice.eth

# GenesisAgentRegistry ("Recompute Kit Bots") — powers /mint. Ethereum mainnet.
NEXT_PUBLIC_GENESIS_REGISTRY_ADDRESS=0x8b5AF3A59f81c7e16617E8Eb824BC6FfB792A2C3
NEXT_PUBLIC_GENESIS_CHAIN_ID=1
